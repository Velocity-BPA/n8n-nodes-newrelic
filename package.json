{
  "name": "n8n-nodes-newrelic",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for New Relic APM and observability platform providing 12 resources and 65+ operations for application monitoring, alerting, dashboards, and NRQL queries.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-newrelic.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-newrelic",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-newrelic/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "newrelic",
    "new-relic",
    "apm",
    "observability",
    "monitoring",
    "alerting",
    "dashboards",
    "nrql",
    "synthetics",
    "devops"
  ],
  "main": "dist/nodes/NewRelic/NewRelic.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/NewRelicApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/NewRelic/NewRelic.node.js",
      "dist/nodes/NewRelic/NewRelicTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}